APP_NAME=NextScout
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.nextscout.app

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info
LOG_DAILY_DAYS=30

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nextscout
DB_USERNAME=nextscout
DB_PASSWORD=change_me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=.nextscout.app

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=nextscout.app,www.nextscout.app,api.nextscout.app

FRONTEND_URL=https://nextscout.app
CORS_ALLOWED_ORIGINS=https://nextscout.app,https://www.nextscout.app

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=change_me
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@nextscout.app
MAIL_FROM_NAME="NextScout"

